# Domain and hosts
DOMAIN=localhost

KEYCLOAK_HOST=auth.${DOMAIN}
ATTACK_VECTOR_HOST=hack.${DOMAIN}
TRAEFIK_HOST=traefik.${DOMAIN}

# Keycloak
KEYCLOAK_DB=keycloak_db
KEYCLOAK_DB_USER=keycloak_db_user
KEYCLOAK_DB_PASSWORD=keycloak_db_user_password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password

# Traefik / LetsEncrypt
# LetsEncrypt contact email
E_MAIL=email@example.com
RESOLVER_NAME=dynu
# DNS resolver configuration
# Exemple for DYNU
DYNU_API_KEY=xxxxx